rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can read and create their own profile document, and update it
    // EXCEPT for the "role" field (so a member can never self-promote to admin —
    // only done manually by RIED staff directly in the Firebase console for now).
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.role == resource.data.role;
    }

    // Blog / video posts (Pramod & Neel only) — public can read, only an
    // account whose /users/{uid} doc has role == "admin" can write.
    match /blogPosts/{postId} {
      allow read: if true;
      allow write: if request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Everything else is closed by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can read and create their own profile document, and update it
    // EXCEPT for the "role" field (so a member can never self-promote to admin —
    // only done manually by RIED staff directly in the Firebase console for now).
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.role == resource.data.role;
    }

    // Blog / video posts (Pramod & Neel only) — public can read, only an
    // account whose /users/{uid} doc has role == "admin" can write.
    match /blogPosts/{postId} {
      allow read: if true;
      allow write: if request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Founder onboarding profile (Basic Info / Company Info / Individual Founder
    // Discovery answers, plus Flywheel stage progress) — each user can read/write
    // their own doc. An admin (role == "admin" on their own /users doc) can also
    // read across all profiles (to list pending stage-advancement requests) and
    // update any profile (to approve an advancement, per the "RIED approves
    // advancement" flow) — but can never self-serve a stage advancement for
    // themselves via a non-admin path, since createUpdate below is still the
    // only other write path and it's uid-scoped.
    // A Cloud Function (onCreate/onWrite trigger) reads this server-side to email
    // a copy to hello@ried.co.in — that server-side read uses the Admin SDK and
    // is not subject to these rules.
    match /profiles/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"));
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"));
    }

    // Founder Flywheel dashboard file uploads (metadata only — the actual file
    // bytes live in Cloud Storage; see storage.rules). Each user can only
    // read/create/delete their own upload records.
    match /uploads/{userId}/files/{fileId} {
      allow read, create, delete: if request.auth != null && request.auth.uid == userId;
      allow update: if false;
    }

    // Everything else is closed by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

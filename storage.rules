rules_version = '2';

// Firebase Storage security rules for the RIED website.
// Two upload areas, both scoped strictly to the signed-in owner:
//   - profile-logos/{uid}/...   company/organisation logo from onboarding
//   - user-uploads/{uid}/...    documents a founder uploads from their dashboard
service firebase.storage {
  match /b/{bucket}/o {

    match /profile-logos/{userId}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /user-uploads/{userId}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 20 * 1024 * 1024;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
